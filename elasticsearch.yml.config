# WARNING: This is a template file. Do not use directly.
# Placeholders: _HOST_IP_, _HOSTNAME_
# Used by: install-elasticedr.sh
#
# Elasticsearch configuration file
#

network.host: _HOST_IP_

# Create a new cluster with the current node only
# Additional nodes can still join the cluster later
# This needs to be the hostname of the machine
cluster.initial_master_nodes: ["_HOSTNAME_"]

# Path to log files:
path.logs: /var/log/elasticsearch

# Path to directory where to store the data (separate multiple locations by comma):
path.data: /var/lib/elasticsearch

# Cluster name
cluster.name: ElasticEDR

# Allow HTTP API connections from anywhere
# Connections are encrypted and require user authentication
http.host: 0.0.0.0

# Enable security features
xpack.security.enabled: true
xpack.security.enrollment.enabled: true
xpack.security.http.ssl.supported_protocols: ["TLSv1.2", "TLSv1.3"]

# Enable encryption for HTTP API client connections, such as Kibana, Logstash, and Agents
xpack.security.http.ssl:
  enabled: true
  # New certificate
  keystore.path: certs/elasticsearch/http.p12

# Enable encryption and mutual authentication between cluster nodes
xpack.security.transport.ssl:
  enabled: true
  verification_mode: certificate
  # Still self-signed from original
  keystore.path: certs/transport.p12
  truststore.path: certs/transport.p12
